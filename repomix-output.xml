    const template = this.templates[specialty];
    return template?.commonInvestigations || [];
  }

  static getUrgencyGuidelines(specialty: string): string {
    const template = this.templates[specialty];
    return template?.urgencyGuidelines || 'ROUTINE unless otherwise indicated';
  }
